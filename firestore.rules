rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidScore(data) {
      return data.userId is string && data.userId.size() <= 128
          && data.username is string && data.username.size() >= 1 && data.username.size() <= 50
          && data.score is int && data.score >= 0 && data.score < 1000000
          && data.isGuest is bool
          && data.createdAt == request.time
          && (!data.keys().hasAll(['photoURL']) || (data.photoURL is string && data.photoURL.size() <= 2048));
    }

    match /scores/{scoreId} {
      // Anyone can read high scores
      allow read: if true;

      // Creating a score
      allow create: if isValidId(scoreId) && isValidScore(incoming()) && (
        // If signed in, userId must match authenticated UID, same for isGuest == false
        (isSignedIn() && incoming().userId == request.auth.uid && incoming().isGuest == false) ||
        // If not signed in, they must be guest
        (!isSignedIn() && incoming().isGuest == true)
      );

      // Scores are immutable once submitted
      allow update, delete: if false;
    }
  }
}
